                        "Ref": "AWS::Partition",
                      },
                      ":iam::xxxxxx:root",
                    ],
                  ],
                },
              },
              "Resource": "*",
            },
          ],
          "Version": "2012-10-17",
        },
      },
      "Type": "AWS::KMS::Key",
      "UpdateReplacePolicy": "Retain",
    },
  },
  "Rules": {
    "ValidateNetworkParametersForDataScience": {
      "Assertions": [
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Equals": [
                  {
                    "Ref": "VpcId",
                  },
                  "",
                ],
              },
            ],
          },
          "AssertDescription": "VPC ID is required.",
        },
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Equals": [
                  {
                    "Ref": "SubnetId",
                  },
                  "",
                ],
              },
            ],
          },
          "AssertDescription": "Subnet ID is required.",
        },
      ],
      "RuleCondition": {
        "Fn::Equals": [
          {
            "Ref": "SampleName",
          },
          "basic_datascience_platform",
        ],
      },
    },
    "ValidateOrganizationName": {
      "Assertions": [
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Equals": [
                  {
                    "Ref": "OrgName",
                  },
                  "",
                ],
              },
            ],
          },
          "AssertDescription": "Organization Name is required for all MDAA deployments",
        },
      ],
    },
  },
}
`;

