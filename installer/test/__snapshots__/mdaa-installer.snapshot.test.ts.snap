        "Source": {
          "BuildSpec": "{
  "version": 0.2,
  "phases": {
    "install": {
      "runtime-versions": {
        "nodejs": 22
      },
      "commands": [
        "git clone --branch $REPOSITORY_BRANCH_NAME --single-branch https://github.com/aws/modern-data-architecture-accelerator.git"
