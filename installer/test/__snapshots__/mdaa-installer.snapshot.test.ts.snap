        "find \${SAMPLE_CONFIG_FOLDER}/\${SAMPLE_NAME}/ -type f \\\\( -name \\"*.yaml\\" -o -name \\"*.yml\\" \\\\) -exec sed -i 's/<your subnet id>/'\\"$SUBNET_ID\\"'/g' {} \\\\;",
