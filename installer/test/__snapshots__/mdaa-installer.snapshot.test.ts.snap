            },
          },
          {
            "Name": "MDAA_VERSION",
            "Type": "PLAINTEXT",
            "Value": {
              "Ref": "MdaaVersion",
            },
          },
        ],
        "Image": "aws/codebuild/standard:7.0",
        "ImagePullCredentialsType": "CODEBUILD",
        "PrivilegedMode": true,
        "Type": "LINUX_CONTAINER",
      },
      "Name": {
        "Fn::Join": [
          "",
          [
            "MDAA-Build-",
