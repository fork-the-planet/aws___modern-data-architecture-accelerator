    "watch": "tsc -w",
    "test:package-docs": "../../../../scripts/generate_docs/test_package_docs.sh"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "devDependencies": {
    "@aws-mdaa/testing": "1.6.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.9.0",
    "jest": "29.7.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-json-schema": "0.67.4"
  },
  "dependencies": {
    "@aws-mdaa/app": "1.6.0",
    "@aws-mdaa/iam-role-helper": "1.6.0",
    "@aws-mdaa/l3-construct": "1.6.0",
