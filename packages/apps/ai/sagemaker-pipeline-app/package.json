{
  "name": "@aws-mdaa/sagemaker-pipeline",
  "description": "MDAA SageMaker Pipeline app — pure CDK pipeline definition via CfnPipeline",
  "author": {
    "name": "Amazon Web Services",
    "url": "https://aws.amazon.com/solutions"
  },
  "bin": {
    "sagemaker-pipeline-cdk": "bin/sagemaker-pipeline.js"
  },
  "version": "1.7.0",
  "license": "Apache-2.0",
  "scripts": {
    "build": "../../../../scripts/build/build_package.sh PipelineConfigContents",
    "watch": "tsc -w",
    "test": "jest --passWithNoTests --coverage",
    "cdk": "cdk",
    "lint": "eslint --max-warnings 0 -c ../../../../eslint.config.mjs",
    "test:update-baselines": "UPDATE_BASELINES=true jest --passWithNoTests --testPathPattern='.*\\.diff\\.test\\.ts'",
    "test:coverage": "jest --passWithNoTests --coverage --testPathIgnorePatterns='.*\\.snapshot\\.test\\.ts'",
    "test:snapshots": "jest --passWithNoTests --testPathPattern='.*\\.snapshot\\.test\\.ts'",
    "test:snapshots:update": "jest --passWithNoTests --testPathPattern='.*\\.snapshot\\.test\\.ts' --updateSnapshot",
    "test:package-docs": "../../../../scripts/generate_docs/test_package_docs.sh"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "devDependencies": {
    "@aws-mdaa/testing": "1.7.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.9.0",
    "jest": "29.7.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-json-schema": "0.67.4"
  },
  "dependencies": {
    "@aws-mdaa/app": "1.7.0",
    "@aws-mdaa/config": "1.7.0",
    "@aws-mdaa/iam-role-helper": "1.7.0",
    "@aws-mdaa/l3-construct": "1.7.0",
    "@aws-mdaa/sagemaker-model-training-l3-construct": "1.7.0",
    "ajv": "8.18.0",
    "aws-cdk-lib": "2.258.0",
    "cdk-nag": "2.37.55",
    "constructs": "10.6.0",
    "source-map-support": "0.5.21",
    "yaml": "1.10.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aws/modern-data-architecture-accelerator"
  }
}
