{
  "name": "@aws-mdaa/sagemaker-model-deploy-l3-construct",
  "version": "1.6.0",
  "description": "MDAA SageMaker Model Deployment L3 Construct",
  "license": "Apache-2.0",
  "author": {
    "name": "Amazon Web Services",
    "url": "https://aws.amazon.com/solutions"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aws/modern-data-architecture-accelerator"
  },
  "scripts": {
    "build": "export JSII_SILENCE_WARNING_UNTESTED_NODE_VERSION=1 && jsii --project-references",
    "watch": "jsii -w  --project-references",
    "package": "jsii-pacmak --npmignore=false",
    "test": "jest --passWithNoTests --coverage",
    "lint": "eslint --max-warnings 0 -c ../../../../../eslint.config.mjs",
    "test:coverage": "jest --passWithNoTests --coverage --testPathIgnorePatterns='.*\\.snapshot\\.test\\.ts'",
    "test:snapshots": "jest --passWithNoTests --testPathPattern='.*\\.snapshot\\.test\\.ts'",
    "test:snapshots:update": "jest --passWithNoTests --testPathPattern='.*\\.snapshot\\.test\\.ts' --updateSnapshot",
    "test:package-docs": "../../../../../scripts/generate_docs/test_package_docs.sh"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "devDependencies": {
    "@aws-mdaa/construct": "1.6.0",
    "@aws-mdaa/iam-role-helper": "1.6.0",
    "@aws-mdaa/l3-construct": "1.6.0",
    "@aws-mdaa/naming": "1.6.0",
    "@aws-mdaa/testing": "1.6.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.9.0",
    "aws-cdk-lib": "2.258.0",
    "constructs": "10.6.0",
    "jest": "29.7.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@aws-mdaa/construct": "1.6.0",
    "@aws-mdaa/iam-role-helper": "1.6.0",
    "@aws-mdaa/l3-construct": "1.6.0",
    "@aws-mdaa/naming": "1.6.0",
    "aws-cdk-lib": "2.258.0",
    "constructs": "10.6.0"
  },
  "dependencies": {
    "@aws-mdaa/construct": "1.6.0",
    "@aws-mdaa/iam-constructs": "1.6.0",
    "@aws-mdaa/iam-role-helper": "1.6.0",
    "@aws-mdaa/kms-constructs": "1.6.0",
    "@aws-mdaa/l3-construct": "1.6.0",
    "@aws-mdaa/lambda-constructs": "1.6.0",
    "@aws-mdaa/naming": "1.6.0",
    "@aws-mdaa/s3-constructs": "1.6.0",
    "@aws-mdaa/sm-shared": "1.6.0",
    "aws-cdk-lib": "2.258.0",
    "cdk-nag": "2.37.55",
    "constructs": "10.6.0"
  },
  "stability": "experimental",
  "jsii": {
    "outdir": "jsii-dist",
    "versionFormat": "full",
    "targets": {},
    "excludeTypescript": [
      "assets/**"
    ]
  }
}
