{
  "name": "@aws-mdaa/mdaa",
  "private": true,
  "bin": "./packages/cli/bin/mdaa",
  "version": "1.7.0",
  "license": "Apache-2.0",
  "scripts": {
    "git-clean": "git clean -Xfd -e !development -e !development/** -e !.vscode -e !.vscode/** -e !.idea -e !.idea/**",
    "build": "./scripts/build/build_repo.sh",
    "build:all": "NX_RUN_ALL=true npm run build",
    "lint": "./scripts/quality/lint_repo.sh",
    "lint:all": "NX_RUN_ALL=true npm run lint",
    "prepare": "husky install source/.husky",
    "prepush": "./scripts/quality/prepush_repo.sh",
    "prepush:all": "NX_RUN_ALL=true npm run prepush",
    "prettier": "./scripts/quality/prettier_repo.sh",
    "prettier:all": "NX_RUN_ALL=true npm run prettier",
    "test": "./scripts/test/test_repo.sh",
    "test:all": "NX_RUN_ALL=true npm run test",
    "test:update-baselines": "./scripts/test/test_update_baselines_repo.sh",
    "test:update-baselines:all": "NX_RUN_ALL=true npm run test:update-baselines",
    "test:package-docs": "./scripts/generate_docs/test_package_docs_repo.sh",
    "test:package-docs:all": "NX_RUN_ALL=true npm run test:package-docs",
    "test:python": "./scripts/test/test_python_repo.sh",
    "test:python:all": "NX_RUN_ALL=true npm run test:python",
    "test:starter-kits": "./scripts/test/test_starter_kits_repo.sh",
    "test:starter-kits:all": "NX_RUN_ALL=true npm run test:starter-kits",
    "delete:snapshots": "find . -path '*/__snapshots__/*.snap' -type f -delete",
    "postinstall": "sed -i 's/\"inBundle\": true,//g' package-lock.json 2>/dev/null || sed -i '' 's/\"inBundle\": true,//g' package-lock.json 2>/dev/null || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings 0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/js-yaml": "4.0.9",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "core-js-pure": "3.43.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.5.0",
    "eslint-plugin-prettier": "5.5.4",
    "husky": "8.0.3",
    "jest": "29.7.0",
    "js-yaml": "4.2.0",
    "jsii": "5.9.44",
    "jsii-config": "1.132.0",
    "jsii-pacmak": "1.132.0",
    "lint-staged": "16.2.7",
    "prettier": "3.7.4",
    "ts-node": "10.9.2",
    "typedoc": "0.28.17"
  },
  "optionalDependencies": {
    "@nx/nx-darwin-arm64": "22.7.6",
    "@nx/nx-darwin-x64": "22.7.6",
    "@nx/nx-freebsd-x64": "22.7.6",
    "@nx/nx-linux-arm-gnueabihf": "22.7.6",
    "@nx/nx-linux-arm64-gnu": "22.7.6",
    "@nx/nx-linux-arm64-musl": "22.7.6",
    "@nx/nx-linux-x64-gnu": "22.7.6",
    "@nx/nx-linux-x64-musl": "22.7.6",
    "@nx/nx-win32-arm64-msvc": "22.7.6",
    "@nx/nx-win32-x64-msvc": "22.7.6"
  },
  "dependencies": {
    "aws-cdk": "^2.1126.0",
    "lerna": "9.0.7",
    "nx": "^22.7.5",
    "typescript": "5.9.3"
  },
  "workspaces": [
    "packages/cli",
    "packages/constructs/L2/*",
    "packages/constructs/L3/*/*",
    "packages/utilities/*",
    "packages/apps/*/*",
    "schemas",
    "integ/constructs",
    "starter_kits"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aws/modern-data-architecture-accelerator"
  }
}
